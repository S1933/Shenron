{
  "agent": {
    "build": {
      "description": "Build and deploy agent",
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.7,
      "permission": {
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "deny"
      },
      "prompt": "{file:./prompts/build.md}",
      "steps": 50
    }
  },
  "command": {
    "ship": {
      "description": "Ship current changes",
      "agent": "build",
      "template": "{file:./command/ship.md}"
    }
  }
}
